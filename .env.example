# Required for grounded ask responses.
OPENAI_API_KEY=
PRECURE_MODEL=gpt-5.5-2026-04-23

# Set to x402 only after all OKX values below are present. Any other value leaves
# local development free and does not initialize the payment middleware.
PRECURE_PAYMENT_MODE=free
FREE_CALLS_PER_DAY=3

# Required for x402 settlement through the OKX Payment SDK.
PAY_TO_ADDRESS=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Optional. Signs the short-lived URL returned by the paid Download Memory
# service. When omitted, a purpose-specific key is derived from OKX_SECRET_KEY.
MEMORY_DOWNLOAD_SECRET=
MEMORY_DOWNLOAD_URL_TTL_SECONDS=300
PRECURE_PUBLIC_BASE_URL=https://precure-production.up.railway.app
